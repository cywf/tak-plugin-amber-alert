# TAK-Server Connection (mTLS) - REQUIRED
TAK_HOST=10.0.0.50
TAK_PORT=8089
TAK_PROTOCOL=tcp
TAK_USE_TLS=true
TAK_CERT_PATH=/certs/client.pem
TAK_KEY_PATH=/certs/client-key.pem
TAK_CA_PATH=/certs/ca.pem
TAK_VERIFY_SSL=true

# AMBER Alert Configuration
AMBER_CHECK_INTERVAL=300  # Check every 5 minutes
AMBER_DATA_DIR=/app/data

# Alert Sources
AMBER_ENABLE_IPAWS=true
AMBER_ENABLE_STATES=true
AMBER_STATES=CA,TX,FL  # Comma-separated state codes

# Geofence Filtering
AMBER_GEOFENCE_FILTER=true
AMBER_GEOFENCE_RADIUS_MILES=100
AMBER_ALERT_LAT=37.7749
AMBER_ALERT_LON=-122.4194

# Logging
LOG_LEVEL=INFO
